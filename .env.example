HOST=0.0.0.0
PORT=3001
DATABASE_URL=sqlite://projects.db

# Auth — must match auth-service settings
AUTH_ENFORCED=true
AUTH_JWT_SECRET=dev-insecure-secret-change-me
AUTH_JWT_ALGORITHM=HS256
AUTH_ISSUER=auth-service
# For RS256: AUTH_JWT_PUBLIC_KEY=<PEM with \n escaped>

# CORS — comma-separated origins, or * for permissive
ALLOWED_ORIGINS=http://localhost:5173

# Rate limiting
RATE_LIMIT_MAX_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
